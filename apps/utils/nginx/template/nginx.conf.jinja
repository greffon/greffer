worker_processes 1;


events {
  # max_clients = worker_processes * worker_connections/4
  worker_connections 256;
}

http {
  map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
  }

  #gzip setup
  gzip on;
  gzip_http_version 1.1;
  gzip_vary on;
  gzip_comp_level 6;
  gzip_proxied any;
  gzip_types text/plain text/css application/json application/x-javascript text/xml application/xml application/xml+rss text/javascript application/javascript text/x-js;
  gzip_buffers 16 8k;

  sendfile on;
  tcp_nopush on;
  tcp_nodelay on;
  #keepalive_timeout 65;
  types_hash_max_size 2048;

  # --- OWASP secure configuration ----
  # Buffer Overflow Protection
  # Size Limits & Buffer Overflows
  # the size may be configured based on the needs.
  client_body_buffer_size 10240K;
  server_names_hash_bucket_size 64;
  client_header_buffer_size 1k;
  client_max_body_size 204800k;
  large_client_header_buffers 2 1k;
  server_tokens off;
  client_body_timeout 10;
  client_header_timeout 10;
  keepalive_timeout 5 5;
  send_timeout 10;

  proxy_connect_timeout 15;
  {% for port in http_ports %}
  upstream {{port.container_name}}_{{port.port_container}} {
    server {{port.container_name}}:{{port.port_container}};
    keepalive_timeout 0;
  }
  {% endfor %}

  # include virtual servers
  {% for port in http_ports %}
  server {
  #listen 443 ssl default_server;
  listen {{port.port_container}} ssl;
  server_name {{port.container_name}}.{{port.port_container}};
  
  ssl_certificate /etc/nginx/pem.crt;
  ssl_certificate_key /etc/nginx/cert.key;

  large_client_header_buffers 32 4096k;

  # --- OWASP secure configuration ----
  # SSL/TLS Configuration
  # SSL protocols TLSv1.2 and higher are allowed. Disabed SSLv3
  ssl_protocols TLSv1.2 TLSv1.3;
  # enables server-side protection from BEAST attacks
  ssl_prefer_server_ciphers on;

  # Disabled insecure ciphers suite. For example, MD5, DES, RC4, PSK
  ssl_ciphers "ECDHE-RSA-AES256-GCM-SHA384:ECDHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384:DHE-RSA-AES128-GCM-SHA256:ECDHE-RSA-AES256-SHA384:ECDHE-RSA-AES128-SHA256:ECDHE-RSA-AES256-SHA:ECDHE-RSA-AES128-SHA:DHE-RSA-AES256-SHA256:DHE-RSA-AES128-SHA256:DHE-RSA-AES256-SHA:DHE-RSA-AES128-SHA:ECDHE-RSA-DES-CBC3-SHA:EDH-RSA-DES-CBC3-SHA:AES256-GCM-SHA384:AES128-GCM-SHA256:AES256-SHA256:AES128-SHA256:AES256-SHA:AES128-SHA:DES-CBC3-SHA:HIGH:!aNULL:!eNULL:!EXPORT:!DES:!MD5:!PSK:!RC4:@STRENGTH";

  # -!MEDIUM:exclude encryption cipher suites using 128 bit encryption.
  # -!LOW:   exclude encryption cipher suites using 64 or 56 bit encryption algorithms
  # -!EXPORT: exclude export encryption algorithms including 40 and 56 bits algorithms.
  # -!aNULL:  exclude the cipher suites offering no authentication. This is currently the anonymous DH algorithms and anonymous ECDH algorithms.
  # These cipher suites are vulnerable to a "man in the middle" attack and so their use is normally discouraged.
  # -!eNULL:exclude the "NULL" ciphers that is those offering no encryption.
  # Because these offer no encryption at all and are a security risk they are disabled unless explicitly included.
  # @STRENGTH:sort the current cipher list in order of encryption algorithm key length.

  # X-Frame-Options is to prevent from clickJacking attack
  # add_header X-Frame-Options "SAMEORIGIN";

  location / {
    proxy_http_version 1.1;
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    # The greffon_nginx terminates TLS on every instance and proxies plain
    # HTTP to the upstream container. Apps that compare the request
    # protocol against their configured public URL (Ghost is the canonical
    # case — there are many: Discourse, GitLab, Mastodon, Vaultwarden,
    # anything Express- or Rails-based that auto-301s on protocol
    # mismatch) will see HTTP, see their configured https:// url, and
    # 301-loop indefinitely. Setting X-Forwarded-Proto here lets those
    # apps detect they're already behind TLS termination and skip the
    # redirect. Hardcoded `https` because greffon_nginx is *only* ever
    # reached over TLS (the `listen 2368 ssl` directive above is the
    # single entry point for upstream traffic).
    proxy_set_header X-Forwarded-Proto https;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $connection_upgrade;
    proxy_set_header Accept-Encoding $http_accept_encoding;
    client_max_body_size 10G;
    proxy_request_buffering off;
{% if port.streaming %}
    # Streaming app (SSE / long-poll / chunked), opted in via the
    # `com.greffon.proxy.streaming` compose label. nginx buffers proxied
    # responses by default, which holds an event stream until the buffer
    # fills and the app's live updates never reach the browser. Disable
    # response buffering and emit X-Accel-Buffering so any outer proxy (the
    # manager edge nginx) disables buffering for this response too: it honors
    # the header natively and needs no per-greffon knowledge.
    #
    # Applies to the whole location, not just the stream path, since the
    # label is per-service not per-path. A streaming greffon's normal
    # (non-stream) responses are proxied unbuffered too, a minor throughput
    # trade-off that is acceptable for these single-tenant apps. The 1h read
    # timeout caps an idle connection; well-behaved SSE (Remotion heartbeats
    # every 10s) resets it continuously, and EventSource reconnects anyway.
    proxy_buffering off;
    proxy_read_timeout 3600s;
    add_header X-Accel-Buffering no always;
{% endif %}
    proxy_pass http://{{port.container_name}}_{{port.port_container}}/;
  }
}
 {% endfor %}
}
