GREFFON_BASE_SERVER="http://host.docker.internal:8000"
GREFFON_PATH=/app/data
GREFFER_ADDRESS="host.docker.internal"
GREFFER_PORT="8001"
GREFFER_PROTOCOL="https"
GREFFER_ID="3d4f7760-b346-4a45-a860-a59982c5683f"
GREFFER_SSL_VERIFY=false
# Tunnel mode only — the sidecar polls this URL for its rathole config.
# Proxy-mode greffers can leave it blank.
MANAGER_URL=
# Tunnel mode only — set to ``tunnel`` so the register payload tells
# manager this greffer's intended mode, matching the value set via
# ``PATCH /api/greffer/{id}/mode/``. Empty / unset → manager treats the
# register as proxy-mode-default. Flipping requires updating both
# manager-side mode AND this var, then restarting greffer.
GREFFER_MODE=
