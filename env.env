GREFFON_BASE_SERVER="http://host.docker.internal:8000"
GREFFON_PATH=/app/data
GREFFER_ADDRESS="host.docker.internal"
GREFFER_PORT="8001"
GREFFER_PROTOCOL="https"
GREFFER_ID="3d4f7760-b346-4a45-a860-a59982c5683f"
# Dev stack talks to manager over http://host.docker.internal:8000 (TLS is
# terminated by the root dev-proxy, not here). Production MUST use https://.
GREFFER_ALLOW_INSECURE_BOOTSTRAP=1